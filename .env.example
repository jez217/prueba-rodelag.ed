# ─── JWT (must match the secret used by the Go service) ───────────────────────
JWT_SECRET=change_me_in_production

# ─── PostgreSQL (Module 1 shared DB) ──────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fintech
DB_USER=fintech_user
DB_PASSWORD=fintech_pass

# ─── Upstream service URLs ─────────────────────────────────────────────────────
GO_SERVICE_URL=http://go-api:8080
AI_SERVICE_URL=http://ai-service:8000

# ─── HTTP client timeouts (seconds) ───────────────────────────────────────────
HTTP_TIMEOUT=10
LLM_TIMEOUT=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
